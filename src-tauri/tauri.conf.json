{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "S3 CloudFront Studio",
  "version": "0.1.0",
  "identifier": "com.nicodev.s3-cloudfront-studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "S3 CloudFront Studio",
        "width": 1440,
        "height": 920,
        "minWidth": 980,
        "minHeight": 680,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Desktop S3 and CloudFront operations console",
    "longDescription": "A cross-platform desktop console for browsing S3 buckets, previewing objects, transferring files, and creating CloudFront invalidations using local AWS CLI credentials."
  }
}
